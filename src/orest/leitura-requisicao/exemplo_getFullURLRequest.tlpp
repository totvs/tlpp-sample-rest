#include "tlpp-core.th"
#include "tlpp-rest.th"
 
// Exemplo de chamada: http://localhost:9090/documentation/getFullURLRequest
@Get("/documentation/getFullURLRequest")
User Function fGetFullURLRequest()
 
Local cReturn := ""
Local cURL    := ""
 
cURL := oRest:getFullURLRequest()
 
cReturn := '{"url": "' + cURL + '"}'
 
ConOut("URL capturada: " + cURL) 
 
oRest:SetResponse(cReturn)
 
Return .T.
